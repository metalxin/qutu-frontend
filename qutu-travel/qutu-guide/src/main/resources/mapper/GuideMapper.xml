<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.sdstudio.qutu.guide.mapper.GuideMapper">

    <resultMap id="GuideSummary" type="cn.sdstudio.qutu.guide.vo.GuideSummaryVO">
        <result property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="cover" column="cover_url"/>
        <result property="summary" column="summary"/>
        <result property="durationText" column="duration_text"/>
        <result property="likeCount" column="like_count"/>
        <result property="viewCount" column="view_count"/>
        <result property="tag" column="tag"/>
    </resultMap>

    <resultMap id="GuideListVO" type="cn.sdstudio.qutu.guide.vo.GuideListVO">
        <result property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="cover" column="cover_url"/>
        <result property="summary" column="summary"/>
        <result property="durationText" column="duration_text"/>
        <result property="likeCount" column="like_count"/>
        <result property="viewCount" column="view_count"/>
        <result property="tag" column="tag"/>
        <result property="cityName" column="city_name"/>
    </resultMap>

    <resultMap id="GuideAdminVO" type="cn.sdstudio.qutu.guide.vo.GuideAdminVO">
        <result property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="coverUrl" column="cover_url"/>
        <result property="summary" column="summary"/>
        <result property="days" column="days"/>
        <result property="nights" column="nights"/>
        <result property="tag" column="tag"/>
        <result property="likeCount" column="like_count"/>
        <result property="viewCount" column="view_count"/>
        <result property="cityId" column="city_id"/>
        <result property="cityName" column="city_name"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <resultMap id="GuideAdminDetailVO" type="cn.sdstudio.qutu.guide.vo.GuideAdminDetailVO">
        <result property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="coverUrl" column="cover_url"/>
        <result property="summary" column="summary"/>
        <result property="days" column="days"/>
        <result property="nights" column="nights"/>
        <result property="tag" column="tag"/>
        <result property="likeCount" column="like_count"/>
        <result property="viewCount" column="view_count"/>
        <result property="cityId" column="city_id"/>
        <result property="cityName" column="city_name"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <!-- 根据景点ID查询相关攻略 -->
    <select id="selectRelatedBySpotId" resultMap="GuideSummary">
        SELECT 
            g.id,
            g.title,
            g.cover_url,
            g.summary,
            CONCAT(g.days, '天', g.nights, '晚') AS duration_text,
            g.like_count,
            g.view_count,
            g.tag
        FROM t_guide g
        INNER JOIN t_guide_spot_map m ON g.id = m.guide_id
        WHERE m.spot_id = #{spotId}
          AND g.status = 1
          AND g.deleted_flag = 0
        ORDER BY g.view_count DESC
        LIMIT #{limit}
    </select>

    <!-- 精选攻略分页 -->
    <select id="selectGuidePage" resultMap="GuideListVO">
        SELECT 
            g.id,
            g.title,
            g.cover_url,
            g.summary,
            CONCAT(g.days, '天', g.nights, '晚') AS duration_text,
            g.like_count,
            g.view_count,
            g.tag,
            g.city_name
        FROM t_guide g
        <where>
            g.status = 1
            AND g.deleted_flag = 0
            <if test="query.keyword != null and query.keyword != ''">
                AND (g.title LIKE CONCAT('%', #{query.keyword}, '%')
                 OR g.summary LIKE CONCAT('%', #{query.keyword}, '%'))
            </if>
            <if test="query.cityId != null">
                AND g.city_id = #{query.cityId}
            </if>
            <if test="query.tag != null and query.tag != ''">
                AND g.tag = #{query.tag}
            </if>
            <if test="query.minDays != null">
                AND g.days &gt;= #{query.minDays}
            </if>
            <if test="query.maxDays != null">
                AND g.days &lt;= #{query.maxDays}
            </if>
        </where>
        <choose>
            <when test="query.orderBy != null and query.orderBy != ''">
                ORDER BY 
                <choose>
                    <when test="query.orderBy == 'viewCount'"> g.view_count </when>
                    <when test="query.orderBy == 'likeCount'"> g.like_count </when>
                    <otherwise> g.created_at </otherwise>
                </choose>
                <choose>
                    <when test="query.orderDirection == 'asc'"> ASC </when>
                    <otherwise> DESC </otherwise>
                </choose>
            </when>
            <otherwise>
                ORDER BY g.view_count DESC
            </otherwise>
        </choose>
    </select>

    <!-- 攻略详情 -->
    <select id="selectGuideDetail" resultType="cn.sdstudio.qutu.guide.vo.GuideDetailVO">
        SELECT 
            g.id,
            g.title,
            g.cover_url AS cover,
            g.summary,
            g.days,
            g.nights,
            g.tag,
            g.like_count,
            g.view_count,
            g.city_name
        FROM t_guide g
        WHERE g.id = #{id} AND g.deleted_flag = 0 AND g.status = 1
    </select>

    <!-- 攻略天列表 -->
    <select id="selectGuideDays" resultType="cn.sdstudio.qutu.guide.vo.GuideDayVO">
        SELECT 
            d.guide_id,
            d.day_index AS dayIndex,
            d.title,
            d.summary
        FROM t_guide_day d
        WHERE d.guide_id = #{guideId}
        ORDER BY d.day_index ASC
    </select>

    <!-- 攻略天条目列表 -->
    <select id="selectGuideDayItems" resultType="cn.sdstudio.qutu.guide.vo.GuideDayItemVO">
        SELECT 
            i.type,
            i.title,
            i.content,
            i.spot_id AS spotId,
            i.order_num AS orderNum
        FROM t_guide_day_item i
        WHERE i.guide_id = #{guideId} AND i.day_index = #{dayIndex}
        ORDER BY i.order_num ASC
    </select>

    <!-- 精选攻略标签（按使用次数倒序） -->
    <select id="selectGuideTags" resultType="cn.sdstudio.qutu.guide.vo.GuideTagVO">
        SELECT 
            g.tag AS name,
            COUNT(1) AS count
        FROM t_guide g
        WHERE g.deleted_flag = 0
          AND g.status = 1
          AND g.tag IS NOT NULL
          AND g.tag != ''
        GROUP BY g.tag
        ORDER BY COUNT(1) DESC
        LIMIT #{limit}
    </select>

    <select id="selectGuideAdminPage" resultMap="GuideAdminVO">
        SELECT
            g.id,
            g.title,
            g.cover_url,
            g.summary,
            g.days,
            g.nights,
            g.tag,
            g.like_count,
            g.view_count,
            g.city_id,
            g.city_name,
            g.status,
            g.created_at,
            g.updated_at
        FROM t_guide g
        <where>
            g.deleted_flag = 0
            <if test="query.keyword != null and query.keyword != ''">
                AND (g.title LIKE CONCAT('%', #{query.keyword}, '%')
                OR g.summary LIKE CONCAT('%', #{query.keyword}, '%')
                OR g.tag LIKE CONCAT('%', #{query.keyword}, '%'))
            </if>
            <if test="query.cityId != null">
                AND g.city_id = #{query.cityId}
            </if>
            <if test="query.cityName != null and query.cityName != ''">
                AND g.city_name LIKE CONCAT('%', #{query.cityName}, '%')
            </if>
            <if test="query.tag != null and query.tag != ''">
                AND g.tag LIKE CONCAT('%', #{query.tag}, '%')
            </if>
            <if test="query.minDays != null">
                AND g.days &gt;= #{query.minDays}
            </if>
            <if test="query.maxDays != null">
                AND g.days &lt;= #{query.maxDays}
            </if>
            <if test="query.status != null">
                AND g.status = #{query.status}
            </if>
        </where>
        <choose>
            <when test="query.orderBy != null and query.orderBy != ''">
                ORDER BY
                <choose>
                    <when test="query.orderBy == 'viewCount'"> g.view_count </when>
                    <when test="query.orderBy == 'likeCount'"> g.like_count </when>
                    <otherwise> g.created_at </otherwise>
                </choose>
                <choose>
                    <when test="query.orderDirection == 'asc'"> ASC </when>
                    <otherwise> DESC </otherwise>
                </choose>
            </when>
            <otherwise>
                ORDER BY g.created_at DESC
            </otherwise>
        </choose>
    </select>

    <select id="selectGuideAdminDetail" resultMap="GuideAdminDetailVO">
        SELECT
            g.id,
            g.title,
            g.cover_url,
            g.summary,
            g.days,
            g.nights,
            g.tag,
            g.like_count,
            g.view_count,
            g.city_id,
            g.city_name,
            g.status,
            g.created_at,
            g.updated_at
        FROM t_guide g
        WHERE g.id = #{id}
          AND g.deleted_flag = 0
    </select>

    <delete id="deleteGuideSpotMaps">
        DELETE FROM t_guide_spot_map WHERE guide_id = #{guideId}
    </delete>

    <insert id="insertGuideSpotMaps">
        INSERT INTO t_guide_spot_map (guide_id, spot_id)
        VALUES
        <foreach collection="spotIds" item="spotId" separator=",">
            (#{guideId}, #{spotId})
        </foreach>
    </insert>

</mapper>
