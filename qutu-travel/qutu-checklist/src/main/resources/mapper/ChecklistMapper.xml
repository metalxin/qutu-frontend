<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.sdstudio.qutu.checklist.mapper.ChecklistMapper">

    <resultMap id="ChecklistAdminVO" type="cn.sdstudio.qutu.checklist.vo.ChecklistAdminVO">
        <result property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="username" column="username"/>
        <result property="title" column="title"/>
        <result property="destination" column="destination"/>
        <result property="departDate" column="depart_date"/>
        <result property="returnDate" column="return_date"/>
        <result property="status" column="status"/>
        <result property="itemsCount" column="items_count"/>
        <result property="checkedCount" column="checked_count"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <resultMap id="ChecklistAdminDetailVO" type="cn.sdstudio.qutu.checklist.vo.ChecklistAdminDetailVO">
        <result property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="username" column="username"/>
        <result property="title" column="title"/>
        <result property="destination" column="destination"/>
        <result property="departDate" column="depart_date"/>
        <result property="returnDate" column="return_date"/>
        <result property="remark" column="remark"/>
        <result property="status" column="status"/>
        <result property="itemsCount" column="items_count"/>
        <result property="checkedCount" column="checked_count"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="selectAdminChecklistPage" resultMap="ChecklistAdminVO">
        SELECT
            c.id,
            c.user_id,
            u.username,
            c.title,
            c.destination,
            c.depart_date,
            c.return_date,
            c.status,
            c.items_count,
            c.checked_count,
            c.created_at
        FROM t_checklist c
        LEFT JOIN sys_user u ON u.user_id = c.user_id
        <where>
            c.deleted_flag = 0
            <if test="query.keyword != null and query.keyword != ''">
                AND (c.title LIKE CONCAT('%', #{query.keyword}, '%')
                OR c.destination LIKE CONCAT('%', #{query.keyword}, '%'))
            </if>
            <if test="query.userId != null">
                AND c.user_id = #{query.userId}
            </if>
            <if test="query.status != null">
                AND c.status = #{query.status}
            </if>
        </where>
        ORDER BY c.created_at DESC
    </select>

    <select id="selectAdminChecklistDetail" resultMap="ChecklistAdminDetailVO">
        SELECT
            c.id,
            c.user_id,
            u.username,
            c.title,
            c.destination,
            c.depart_date,
            c.return_date,
            c.remark,
            c.status,
            c.items_count,
            c.checked_count,
            c.created_at,
            c.updated_at
        FROM t_checklist c
        LEFT JOIN sys_user u ON u.user_id = c.user_id
        WHERE c.id = #{id}
          AND c.deleted_flag = 0
    </select>

    <!-- 用户面 ResultMap -->
    <resultMap id="ChecklistListVO" type="cn.sdstudio.qutu.checklist.vo.ChecklistListVO">
        <result property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="destination" column="destination"/>
        <result property="departDate" column="depart_date"/>
        <result property="returnDate" column="return_date"/>
        <result property="status" column="status"/>
        <result property="itemsCount" column="items_count"/>
        <result property="checkedCount" column="checked_count"/>
        <result property="budget" column="budget"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="selectMyChecklistPage" resultMap="ChecklistListVO">
        SELECT
            id,
            title,
            destination,
            depart_date,
            return_date,
            status,
            items_count,
            checked_count,
            budget,
            created_at
        FROM t_checklist
        WHERE deleted_flag = 0
          AND user_id = #{userId}
        ORDER BY created_at DESC
    </select>

</mapper>
