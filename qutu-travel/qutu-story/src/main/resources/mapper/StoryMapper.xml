<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.sdstudio.qutu.story.mapper.StoryMapper">

    <resultMap id="StoryListVO" type="cn.sdstudio.qutu.story.vo.StoryListVO">
        <result property="id" column="id"/>
        <result property="content" column="content"/>
        <result property="firstImage" column="first_image"/>
        <result property="imagesCount" column="images_count"/>
        <result property="locationName" column="location_name"/>
        <result property="recordDate" column="record_date"/>
        <result property="weekday" column="weekday"/>
        <result property="mood" column="mood"/>
        <result property="weather" column="weather"/>
    </resultMap>

    <select id="selectStoryPage" resultMap="StoryListVO">
        SELECT 
            s.id,
            s.content,
            s.images_count,
            s.location_name,
            s.record_date,
            DATE_FORMAT(s.record_date, '%W') AS weekday,
            s.mood,
            s.weather,
            (SELECT url FROM t_story_image i WHERE i.story_id = s.id ORDER BY i.order_num ASC LIMIT 1) AS first_image
        FROM t_story s
        WHERE s.user_id = #{userId} AND s.deleted_flag = 0
        <if test="recordDate != null">
            AND s.record_date = #{recordDate}
        </if>
        ORDER BY s.record_date DESC, s.id DESC
    </select>

    <resultMap id="StoryDetailVO" type="cn.sdstudio.qutu.story.vo.StoryDetailVO">
        <result property="id" column="id"/>
        <result property="content" column="content"/>
        <result property="locationName" column="location_name"/>
        <result property="lng" column="lng"/>
        <result property="lat" column="lat"/>
        <result property="recordDate" column="record_date"/>
        <result property="weekday" column="weekday"/>
        <result property="mood" column="mood"/>
        <result property="weather" column="weather"/>
    </resultMap>

    <select id="selectStoryDetail" resultMap="StoryDetailVO">
        SELECT 
            s.id,
            s.content,
            s.location_name,
            s.lng,
            s.lat,
            s.record_date,
            DATE_FORMAT(s.record_date, '%W') AS weekday,
            s.mood,
            s.weather
        FROM t_story s
        WHERE s.id = #{id} AND s.user_id = #{userId} AND s.deleted_flag = 0
    </select>

    <!-- ===== 后台管理 ===== -->

    <resultMap id="StoryAdminVO" type="cn.sdstudio.qutu.story.vo.StoryAdminVO">
        <result property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="username" column="username"/>
        <result property="content" column="content"/>
        <result property="firstImage" column="first_image"/>
        <result property="imagesCount" column="images_count"/>
        <result property="locationName" column="location_name"/>
        <result property="recordDate" column="record_date"/>
        <result property="mood" column="mood"/>
        <result property="weather" column="weather"/>
        <result property="visibility" column="visibility"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="selectAdminStoryPage" resultMap="StoryAdminVO">
        SELECT
            s.id,
            s.user_id,
            u.username,
            s.content,
            s.images_count,
            s.location_name,
            s.record_date,
            s.mood,
            s.weather,
            s.visibility,
            s.created_at,
            (SELECT url FROM t_story_image i WHERE i.story_id = s.id ORDER BY i.order_num ASC LIMIT 1) AS first_image
        FROM t_story s
        LEFT JOIN sys_user u ON u.user_id = s.user_id
        WHERE s.deleted_flag = 0
        <if test="query.keyword != null and query.keyword != ''">
            AND (s.content LIKE CONCAT('%', #{query.keyword}, '%') OR s.location_name LIKE CONCAT('%', #{query.keyword}, '%'))
        </if>
        <if test="query.userId != null">
            AND s.user_id = #{query.userId}
        </if>
        <if test="query.recordDate != null">
            AND s.record_date = #{query.recordDate}
        </if>
        <if test="query.mood != null and query.mood != ''">
            AND s.mood = #{query.mood}
        </if>
        <if test="query.weather != null and query.weather != ''">
            AND s.weather = #{query.weather}
        </if>
        <if test="query.visibility != null">
            AND s.visibility = #{query.visibility}
        </if>
        ORDER BY s.created_at DESC
    </select>

    <resultMap id="StoryAdminDetailVO" type="cn.sdstudio.qutu.story.vo.StoryAdminDetailVO">
        <result property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="username" column="username"/>
        <result property="content" column="content"/>
        <result property="locationName" column="location_name"/>
        <result property="lng" column="lng"/>
        <result property="lat" column="lat"/>
        <result property="recordDate" column="record_date"/>
        <result property="mood" column="mood"/>
        <result property="weather" column="weather"/>
        <result property="visibility" column="visibility"/>
        <result property="spotId" column="spot_id"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="selectAdminStoryDetail" resultMap="StoryAdminDetailVO">
        SELECT
            s.id,
            s.user_id,
            u.username,
            s.content,
            s.location_name,
            s.lng,
            s.lat,
            s.record_date,
            s.mood,
            s.weather,
            s.visibility,
            s.spot_id,
            s.created_at,
            s.updated_at
        FROM t_story s
        LEFT JOIN sys_user u ON u.user_id = s.user_id
        WHERE s.id = #{id} AND s.deleted_flag = 0
    </select>

</mapper>
